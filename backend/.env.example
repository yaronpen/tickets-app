APP_NAME=TicketsAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── SQL Server ─────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlsrv
DB_HOST=sqlserver
DB_PORT=1433
DB_DATABASE=tickets_db
DB_USERNAME=sa
DB_PASSWORD=YourStrong@Passw0rd

# ── Cache / Queue / Session ────────────────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail (optional) ────────────────────────────────────────────────────────────
MAIL_MAILER=log
